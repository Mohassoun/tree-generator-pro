{
  "name": "file-branch",
  "displayName": "Tree Generator Pro",
  "description": "Generate professional file trees from Explorer selection or workspace root.",
  "version": "1.0.4",
  "publisher": "mohamad--hassoun",
  "author": {
    "name": "Mohamad Hassoun",
    "email": "mohamadhassoun21698@gmail.com",
    "url": "https://portfoliohassoun.web.app/"
  },
  "homepage": "https://portfoliohassoun.web.app/",
  "icon": "images/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Snippets"
  ],
  "keywords": [
    "tree",
    "file tree",
    "workspace",
    "explorer",
    "mohamad-hassoun",
    "clipboard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Mohassoun/tree-generator-pro.git"
  },
  "activationEvents": [
    "onCommand:extension.generateFromSelection",
    "onCommand:extension.generateFromRoot",
    "onCommand:extension.generateToClipboard",
    "onCommand:extension.refreshTreeExplorer",
    "onCommand:extension.copyPath",
    "onView:explorerTreeView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.generateFromSelection",
        "title": "Tree Generator: Generate From Selection"
      },
      {
        "command": "extension.generateFromRoot",
        "title": "Tree Generator: Generate From Workspace Root"
      },
      {
        "command": "extension.generateToClipboard",
        "title": "Tree Generator: Generate To Clipboard",
        "icon": "$(copy)"
      },
      {
        "command": "extension.refreshTreeExplorer",
        "title": "Explorer Tree: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "extension.copyPath",
        "title": "Copy Path",
        "icon": "$(copy)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "explorerTree",
          "title": "Explorer Tree",
          "icon": "images/explorer-tree.svg"
        }
      ]
    },
    "views": {
      "explorerTree": [
        {
          "id": "explorerTreeView",
          "name": "Explorer Tree"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "extension.generateFromSelection",
          "when": "explorerViewletVisible && resourceScheme == file",
          "group": "navigation@100"
        },
        {
          "command": "extension.generateToClipboard",
          "when": "explorerViewletVisible && resourceScheme == file",
          "group": "navigation@101"
        },
        {
          "command": "extension.copyPath",
          "when": "explorerViewletVisible && resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@102"
        }
      ],
      "view/title": [
        {
          "command": "extension.generateToClipboard",
          "when": "view == workbench.explorer.fileView",
          "group": "navigation"
        },
        {
          "command": "extension.refreshTreeExplorer",
          "when": "view == explorerTreeView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "extension.copyPath",
          "when": "view == explorerTreeView && viewItem == treeNode",
          "group": "inline"
        },
        {
          "command": "extension.copyPath",
          "when": "view == explorerTreeView && viewItem == treeNode",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Tree Generator Pro",
      "properties": {
        "treeGenerator.excludedFolders": {
          "type": "array",
          "default": [
            ".git",
            "node_modules",
            ".vscode-test"
          ],
          "description": "Folder names to exclude while generating trees.",
          "items": {
            "type": "string"
          }
        },
        "treeGenerator.maxDepth": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "description": "Maximum folder depth to traverse."
        },
        "treeGenerator.showHiddenFiles": {
          "type": "boolean",
          "default": false,
          "description": "Include files and folders that start with a dot."
        },
        "treeGenerator.outputMode": {
          "type": "string",
          "enum": [
            "webview",
            "text"
          ],
          "default": "webview",
          "description": "Default output mode for generated trees."
        },
        "treeGenerator.foldersFirst": {
          "type": "boolean",
          "default": true,
          "description": "Sort folders before files."
        },
        "treeGenerator.sortMode": {
          "type": "string",
          "enum": [
            "alphabetical",
            "byType"
          ],
          "default": "alphabetical",
          "description": "Sort entries alphabetically or by file type."
        },
        "treeGenerator.timeoutMs": {
          "type": "number",
          "default": 5000,
          "minimum": 500,
          "description": "Stop generation if it exceeds this timeout in milliseconds."
        },
        "treeGenerator.maxItems": {
          "type": "number",
          "default": 5000,
          "minimum": 100,
          "description": "Maximum number of rendered tree lines."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node ./node_modules/typescript/bin/tsc -p ./",
    "watch": "node ./node_modules/typescript/bin/tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "node ./node_modules/typescript/bin/tsc -p ./ --noEmit",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "eslint": "^8.34.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5",
    "@vscode/test-electron": "^2.2.3"
  }
}
